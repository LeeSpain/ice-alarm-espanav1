  "faq": {
    "testPendant": {
      "question": "¿Cómo pruebo mi colgante?",
      "answer": "Mantenga presionado el botón SOS durante 3 segundos. Nuestro equipo contestará y confirmará que su dispositivo funciona correctamente. Recomendamos probar su colgante una vez al mes."
    },
    "sosButton": {
      "question": "¿Qué sucede cuando presiono el botón SOS?",
      "answer": "Cuando mantiene presionado el botón SOS durante 3 segundos, se envía una alerta a nuestro centro de monitoreo 24/7. Un operador capacitado le hablará inmediatamente a través de su colgante y coordinará cualquier asistencia necesaria."
    },
    "fallDetection": {
      "question": "¿Cómo funciona la detección de caídas?",
      "answer": "Su colgante contiene sensores que pueden detectar movimientos bruscos consistentes con una caída. Si se detecta una caída, se envía automáticamente una alerta a nuestro equipo. Le llamaremos a través de su colgante para verificar su estado, y si no hay respuesta, seguiremos su protocolo de emergencia."
    },
    "geoFencing": {
      "question": "¿Qué es el geo-cercado?",
      "answer": "El geo-cercado crea un límite virtual alrededor de una ubicación (como su casa). Si sale de este límite, se puede enviar una alerta a los contactos designados. Esto es útil para mayor tranquilidad para usted y su familia."
    },
    "updateMedical": {
      "question": "¿Cómo actualizo mi información médica?",
      "answer": "Vaya a la sección 'Información médica' en su panel. Haga clic en 'Solicitar actualización' y describa los cambios que desea realizar. Nuestro equipo revisará y actualizará sus registros en 24-48 horas."
    },
    "addContacts": {
      "question": "¿Cómo añado contactos de emergencia?",
      "answer": "Vaya a 'Contactos de emergencia' en su panel. Puede añadir hasta 3 contactos de emergencia. Estas son las personas a las que llamaremos si no podemos comunicarnos con usted durante una emergencia."
    },
    "updatePayment": {
      "question": "¿Cómo actualizo mi método de pago?",
      "answer": "Vaya a 'Suscripción y facturación' en su panel. Haga clic en 'Actualizar' junto a su método de pago para actualizar de forma segura los datos de su tarjeta."
    },
    "lostPendant": {
      "question": "¿Qué pasa si mi colgante se pierde o se daña?",
      "answer": "¡Contáctenos inmediatamente! Podemos desactivar su colgante antiguo y enviarle uno de reemplazo. Puede haber una tarifa de reemplazo dependiendo de las circunstancias. Llámenos o use el formulario de contacto a continuación."
    },
    "upgradePlan": {
      "question": "¿Puedo cambiar de membresía Individual a Pareja?",
      "answer": "¡Sí! Contacte a nuestro equipo de soporte y le ayudaremos a actualizar su membresía. La diferencia prorrateada se cargará a su método de pago registrado."
    }
  },
